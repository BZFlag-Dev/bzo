# Step-height test boxes.
# These heights are in BZFlag map units so the same map is useful in both
# bzfs/bzflag and bzo. bzo now runs a 1:1 BZFlag world scale.
box
name "step_low"
position -42.0 -42.0 0.0
rotation 0.0
size     8.0 8.0 0.25
end

box
name "step_medium"
position -34.0 -42.0 0.25
rotation 0.0
size     8.0 8.0 0.25
end

box
name "step_high"
position -26.0 -42.0 0.5
rotation 0.0
size     8.0 8.0 0.25
end

# Repeated same-size stack for bump-height testing.
# Each layer adds 0.25 BZFlag world units of height.
# This lets us test whether many small stacked rises remain climbable even when
# the outside looks like one continuous tall wall.
box
name "stack1"
position -42.0 -30.0 0.0
rotation 0.0
size     8.0 8.0 0.25
end

